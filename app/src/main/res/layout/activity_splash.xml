<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash Screen Layout
    Features: Lottie animation center-stage, app name with glowing text, animated tagline.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    tools:context=".ui.SplashActivity">

    <!-- Decorative top-left glow blob -->
    <View
        android:id="@+id/glowTopLeft"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:alpha="0.25"
        android:background="@drawable/bg_scan_pulse"
        app:layout_constraintEnd_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="-80dp"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Decorative bottom-right glow blob -->
    <View
        android:id="@+id/glowBottomRight"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:alpha="0.20"
        android:background="@drawable/bg_scan_pulse"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp" />

    <!-- Lottie animation (music/wave animation) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:lottie_fileName="music_wave.json"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_speed="1.0"
        app:layout_constraintBottom_toTopOf="@id/appTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp" />

    <!-- App name -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/white"
        android:textSize="@dimen/text_display"
        android:fontFamily="@font/poppins_bold"
        android:letterSpacing="0.1"
        android:shadowColor="@color/primary"
        android:shadowRadius="20"
        android:shadowDx="0"
        android:shadowDy="0"
        app:layout_constraintBottom_toTopOf="@id/appTagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- App tagline -->
    <TextView
        android:id="@+id/appTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_md"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Bottom loader dots -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/primary"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
